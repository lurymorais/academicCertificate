msgid "plugins.generic.academicCertificate.statistics.title"
msgstr "Statystyki Certyfikatów"

msgid "plugins.generic.academicCertificate.statistics.description"
msgstr "Przegląd generowania i wykorzystania certyfikatów w Twoim czasopiśmie"

