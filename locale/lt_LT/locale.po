msgstr "Failo įkėlimas nepavyko. Prašome bandyti dar kartą."

msgid "plugins.generic.academicCertificate.settings.fontUnicodeWarning"
msgstr "Pastaba: Helvetica, Times New Roman ir Courier šriftai palaiko tik lotyniškus simbolius. Jei jūsų žurnalas naudoja nelotyniškus simbolius, įskiepis automatiškai naudos DejaVu Sans šriftą."

# Error messages
msgid "plugins.generic.academicCertificate.error.reviewNotCompleted"
msgstr "Ši recenzija dar nėra užbaigta. Sertifikatai galimi tik užbaigtoms recenzijoms."

