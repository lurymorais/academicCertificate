# Plugin metadata
msgid "plugins.generic.academicCertificate.displayName"
msgstr "Gerenciador de Certificados Acadêmicos para OJS"

msgid "plugins.generic.academicCertificate.description"
msgstr "Gere e gerencie certificados acadêmicos em PDF para avaliadores, autores e editores — documentos de aprovação, publicação e editoriais com verificação pública."

# Certificate titles
msgid "plugins.generic.academicCertificate.certificateTitle"
msgstr "Certificado de Avaliação"

msgid "plugins.generic.academicCertificate.certificateSubject"
msgstr "Certificado de Avaliação por Pares"

# Dashboard messages
msgid "plugins.generic.academicCertificate.certificateAvailable"
msgstr "Seu certificado está pronto!"

msgid "plugins.generic.academicCertificate.certificateAvailableDescription"
msgstr "Obrigado por concluir esta avaliação. Agora você pode baixar seu certificado de reconhecimento."

