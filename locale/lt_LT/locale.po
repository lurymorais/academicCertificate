msgstr "Nepasirinkti recenzentai masiniam sertifikatų generavimui"

msgid "plugins.generic.academicCertificate.error.accessDenied"
msgstr "Prieiga uždrausta. Neturite leidimo atsisiųsti šio sertifikato."

msgid "plugins.generic.academicCertificate.error.noContext"
msgstr "Nėra žurnalo konteksto. Įsitikinkite, kad prieinate iš galiojančio žurnalo."

msgid "plugins.generic.academicCertificate.error.daoNotAvailable"
msgstr "Duomenų bazės prieiga šiuo metu negalima. Prašome susisiekti su sistemos administratoriumi."

