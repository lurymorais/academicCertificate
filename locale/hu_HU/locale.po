msgstr "Nincs megadva tanúsítvány kód"

msgid "plugins.generic.academicCertificate.error.invalidCertificate"
msgstr "Érvénytelen tanúsítvány kód. Ez a tanúsítvány nem ellenőrizhető."

msgid "plugins.generic.academicCertificate.error.noReviewersSelected"
msgstr "Nincs kiválasztva bíráló a tömeges tanúsítvány generáláshoz"

msgid "plugins.generic.academicCertificate.error.accessDenied"
msgstr "Hozzáférés megtagadva. Nincs jogosultsága letölteni ezt a tanúsítványt."

msgid "plugins.generic.academicCertificate.error.noContext"
msgstr "Nincs elérhető folyóirat kontextus. Kérjük, győződjön meg róla, hogy érvényes folyóiratból fér hozzá."

msgid "plugins.generic.academicCertificate.error.daoNotAvailable"
msgstr "Az adatbázis hozzáférés jelenleg nem elérhető. Kérjük, lépjen kapcsolatba a rendszergazdával."

