# Plugin metadata
msgid "plugins.generic.academicCertificate.displayName"
msgstr "Academic Certificate Manager for OJS"

msgid "plugins.generic.academicCertificate.description"
msgstr "Generate and manage PDF academic certificates for reviewers, authors, and editors — acceptance, publication, and editorial documents with public verification."

# Certificate titles
msgid "plugins.generic.academicCertificate.certificateTitle"
msgstr "Сертификат за Рецензия"

msgid "plugins.generic.academicCertificate.certificateSubject"
msgstr "Сертификат за Експертна Оценка"

# Dashboard messages
msgid "plugins.generic.academicCertificate.certificateAvailable"
msgstr "Вашият Сертификат е Готов!"

msgid "plugins.generic.academicCertificate.certificateAvailableDescription"
msgstr "Благодарим ви за завършването на тази рецензия. Сега можете да изтеглите вашия сертификат за признание."

msgid "plugins.generic.academicCertificate.certificateWillBeGenerated"
msgstr "Вашият сертификат ще бъде автоматично генериран, когато щракнете върху бутона за изтегляне."

msgid "plugins.generic.academicCertificate.downloadCertificate"
msgstr "Изтегли Сертификат"

# Settings form
msgid "plugins.generic.academicCertificate.settings.description"
msgstr "Configure certificate templates, document types, and eligibility rules."

msgid "plugins.generic.academicCertificate.settings.templateSettings"
msgstr "Настройки на Шаблона за Сертификат"

msgid "plugins.generic.academicCertificate.settings.backgroundImage"
msgstr "Фоново Изображение"

msgid "plugins.generic.academicCertificate.settings.backgroundImageDescription"
msgstr "Качете фоново изображение за сертификата (JPG или PNG, препоръчителен размер: 2100x2970 пиксела за A4)"

msgid "plugins.generic.academicCertificate.settings.currentImage"
msgstr "Текущо фоново изображение"

msgid "plugins.generic.academicCertificate.settings.headerText"
msgstr "Заглавен Текст"

msgid "plugins.generic.academicCertificate.settings.headerTextDescription"
msgstr "Основното заглавие, показвано в горната част на сертификата"

msgid "plugins.generic.academicCertificate.settings.headerTextRequired"
msgstr "Заглавният текст е задължителен"

msgid "plugins.generic.academicCertificate.settings.bodyTemplate"
msgstr "Шаблон на Съдържанието на Сертификата"

msgid "plugins.generic.academicCertificate.settings.bodyTemplateDescription"
msgstr "Основното съдържание на сертификата. Използвайте шаблонни променливи за вмъкване на динамично съдържание."

msgid "plugins.generic.academicCertificate.settings.bodyTemplateRequired"
msgstr "Шаблонът на съдържанието на сертификата е задължителен"

msgid "plugins.generic.academicCertificate.settings.footerText"
msgstr "Текст в Долната Част"

msgid "plugins.generic.academicCertificate.settings.footerTextDescription"
msgstr "Незадължителен текст, показван в долната част на сертификата"

msgid "plugins.generic.academicCertificate.settings.availableVariables"
msgstr "Налични Шаблонни Променливи"

msgid "plugins.generic.academicCertificate.settings.availableVariablesDescription"
msgstr "Използвайте тези променливи във вашите шаблони за вмъкване на динамично съдържание:"

msgid "plugins.generic.academicCertificate.settings.defaultTemplate"
msgstr "Шаблон по подразбиране"

msgid "plugins.generic.academicCertificate.settings.useDefaultTemplate"
msgstr "Използвай шаблон по подразбиране"

msgid "plugins.generic.academicCertificate.settings.appearance"
msgstr "Настройки на Външния Вид"

msgid "plugins.generic.academicCertificate.settings.fontFamily"
msgstr "Шрифтово Семейство"

msgid "plugins.generic.academicCertificate.settings.font.helvetica"
msgstr "Helvetica"

msgid "plugins.generic.academicCertificate.settings.font.times"
msgstr "Times New Roman"

msgid "plugins.generic.academicCertificate.settings.font.courier"
msgstr "Courier"

msgid "plugins.generic.academicCertificate.settings.font.dejavusans"
msgstr "DejaVu Sans"

msgid "plugins.generic.academicCertificate.settings.fontSize"
msgstr "Размер на Шрифта"

msgid "plugins.generic.academicCertificate.settings.pageOrientation"
msgstr "Page Orientation"

msgid "plugins.generic.academicCertificate.settings.pageOrientationDescription"
msgstr "Choose portrait (vertical) or landscape (horizontal) layout for the certificate"

msgid "plugins.generic.academicCertificate.settings.orientation.portrait"
msgstr "Portrait (Vertical)"

msgid "plugins.generic.academicCertificate.settings.orientation.landscape"
msgstr "Landscape (Horizontal)"

msgid "plugins.generic.academicCertificate.settings.textColor"
msgstr "Цвят на Текста (RGB)"

msgid "plugins.generic.academicCertificate.settings.textColorDescription"
msgstr "Посочете цвета на текста, като използвате RGB стойности (0-255 за всеки компонент)"

msgid "plugins.generic.academicCertificate.settings.eligibility"
msgstr "Критерии за Допустимост"

msgid "plugins.generic.academicCertificate.settings.minimumReviews"
msgstr "Минимален Брой Завършени Рецензии"

msgid "plugins.generic.academicCertificate.settings.minimumReviewsDescription"
msgstr "Минималният брой завършени рецензии, необходими преди рецензентът да може да получи сертификат"

msgid "plugins.generic.academicCertificate.settings.minimumReviewsInvalid"
msgstr "Минималният брой рецензии трябва да е число, по-голямо или равно на 1"

msgid "plugins.generic.academicCertificate.settings.verification"
msgstr "Опции за Проверка"

msgid "plugins.generic.academicCertificate.settings.includeQRCode"
msgstr "Включи QR код за проверка на сертификата"

msgid "plugins.generic.academicCertificate.settings.previewCertificate"
msgstr "Преглед на Сертификата"

msgid "plugins.generic.academicCertificate.settings.invalidImageType"
msgstr "Невалиден тип изображение. Моля, качете JPG или PNG файл."

msgid "plugins.generic.academicCertificate.settings.uploadFailed"
msgstr "Качването на файла е неуспешно. Моля, опитайте отново."

msgid "plugins.generic.academicCertificate.settings.fontUnicodeWarning"
msgstr "Забележка: Helvetica, Times New Roman и Courier поддържат само латински символи. Ако вашето списание използва кирилица, арабски, китайски или други нелатински символи, приставката автоматично ще използва DejaVu Sans за тези текстови елементи."

# Error messages
msgid "plugins.generic.academicCertificate.error.reviewNotCompleted"
msgstr "Тази рецензия все още не е завършена. Сертификатите са налични само за завършени рецензии."

msgid "plugins.generic.academicCertificate.error.noCertificateCode"
msgstr "Не е предоставен код на сертификат"

msgid "plugins.generic.academicCertificate.error.invalidCertificate"
msgstr "Невалиден код на сертификат. Този сертификат не може да бъде проверен."

msgid "plugins.generic.academicCertificate.error.noReviewersSelected"
msgstr "Не са избрани рецензенти за масово генериране на сертификати"

msgid "plugins.generic.academicCertificate.error.accessDenied"
msgstr "Достъпът е отказан. Нямате разрешение да изтеглите този сертификат."

msgid "plugins.generic.academicCertificate.error.noContext"
msgstr "Няма наличен контекст на списание. Моля, уверете се, че достъпвате от валидно списание."

msgid "plugins.generic.academicCertificate.error.daoNotAvailable"
msgstr "Достъпът до базата данни в момента не е наличен. Моля, свържете се със системния администратор."

# Verification
msgid "plugins.generic.academicCertificate.verify.title"
msgstr "Проверка на Сертификат"

msgid "plugins.generic.academicCertificate.verify.description"
msgstr "Въведете кода на сертификата, за да проверите неговата автентичност"

msgid "plugins.generic.academicCertificate.verify.code"
msgstr "Код на Сертификат"

msgid "plugins.generic.academicCertificate.verify.button"
msgstr "Провери Сертификат"

msgid "plugins.generic.academicCertificate.verify.valid"
msgstr "Валиден Сертификат"

msgid "plugins.generic.academicCertificate.verify.invalid"
msgstr "Невалиден Сертификат"

msgid "plugins.generic.academicCertificate.verify.invalidDescription"
msgstr "Въведеният код на сертификат е невалиден или не съществува в нашата система."

msgid "plugins.generic.academicCertificate.verify.certificateCode"
msgstr "Код на Сертификат"

msgid "plugins.generic.academicCertificate.verify.reviewerName"
msgstr "Име на Рецензента"

msgid "plugins.generic.academicCertificate.verify.journalName"
msgstr "Име на Списанието"

msgid "plugins.generic.academicCertificate.verify.dateIssued"
msgstr "Дата на Издаване"

# Batch generation
msgid "plugins.generic.academicCertificate.batch.title"
msgstr "Масово Генериране на Сертификати"

msgid "plugins.generic.academicCertificate.batch.description"
msgstr "Генерирайте сертификати за множество рецензенти наведнъж. Изберете рецензенти от списъка по-долу, които са завършили рецензии, но все още нямат сертификати."

msgid "plugins.generic.academicCertificate.batch.selectReviewers"
msgstr "Избери Рецензенти"

msgid "plugins.generic.academicCertificate.batch.completedReviews"
msgstr "завършени рецензии"

msgid "plugins.generic.academicCertificate.batch.noEligibleReviewers"
msgstr "Не са намерени допустими рецензенти. Всички рецензенти имат сертификати за завършените си рецензии."

msgid "plugins.generic.academicCertificate.batch.selectMultipleHint"
msgstr "Задръжте Ctrl (Windows/Linux) или Cmd (Mac), за да изберете множество рецензенти"

msgid "plugins.generic.academicCertificate.batch.generate"
msgstr "Генерирай Сертификати"

msgid "plugins.generic.academicCertificate.batch.generating"
msgstr "Генериране на сертификати..."

msgid "plugins.generic.academicCertificate.batch.noSelection"
msgstr "Моля, изберете поне един рецензент"

msgid "plugins.generic.academicCertificate.batch.certificatesGenerated"
msgstr "сертификат(и) успешно генериран(и)"

msgid "plugins.generic.academicCertificate.batch.error"
msgstr "Възникна грешка при генерирането на сертификати. Моля, опитайте отново."

msgid "plugins.generic.academicCertificate.batch.generated"
msgstr "{$count} сертификат(и) успешно генериран(и)"

# Statistics
msgid "plugins.generic.academicCertificate.statistics.title"
msgstr "Статистика на Сертификатите"

msgid "plugins.generic.academicCertificate.statistics.description"
msgstr "Преглед на генерирането и използването на сертификати във вашето списание"

msgid "plugins.generic.academicCertificate.statistics.totalCertificates"
msgstr "Общо Издадени Сертификати"

msgid "plugins.generic.academicCertificate.statistics.totalDownloads"
msgstr "Общо Изтегляния"

msgid "plugins.generic.academicCertificate.statistics.uniqueReviewers"
msgstr "Уникални Рецензенти със Сертификати"

msgid "plugins.generic.academicCertificate.stats.totalIssued"
msgstr "Общо Издадени Сертификати"

msgid "plugins.generic.academicCertificate.stats.totalDownloads"
msgstr "Общо Изтегляния"

msgid "plugins.generic.academicCertificate.stats.averageDownloads"
msgstr "Средно Изтегляния на Сертификат"

msgid "plugins.generic.academicCertificate.settings"
msgstr "Настройки на Сертификата"

msgid "plugins.generic.academicCertificate.myCertificates.title"
msgstr "Моите сертификати"

msgid "plugins.generic.academicCertificate.myCertificates.description"
msgstr "По-долу е списъкът с всички ваши рецензентски сертификати за това списание."

msgid "plugins.generic.academicCertificate.myCertificates.dateIssued"
msgstr "Дата на издаване"

msgid "plugins.generic.academicCertificate.myCertificates.submissionTitle"
msgstr "Заглавие на подаването"

msgid "plugins.generic.academicCertificate.myCertificates.certificateCode"
msgstr "Код на сертификата"

msgid "plugins.generic.academicCertificate.myCertificates.actions"
msgstr "Действия"

msgid "plugins.generic.academicCertificate.myCertificates.noCertificates"
msgstr "Все още нямате сертификати. Сертификатите се генерират след завършване на рецензия."

msgid "plugins.generic.academicCertificate.myCertificates.viewAll"
msgstr "Вижте всички мои сертификати"

