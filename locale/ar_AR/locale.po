msgstr "حدد لون النص باستخدام قيم RGB (0-255 لكل مكون)"

msgid "plugins.generic.academicCertificate.settings.eligibility"
msgstr "معايير الأهلية"

msgid "plugins.generic.academicCertificate.settings.minimumReviews"
msgstr "الحد الأدنى من التحكيمات المكتملة"

